    <NestedLiveVariables>
      <NestedVariableSettingsCollection>
        <ID>com.sysprogs.AllGlobals</ID>
        <Variables />
      </NestedVariableSettingsCollection>
      <NestedVariableSettingsCollection>
        <ID>com.sysprogs.SpecificVariables</ID>
        <Variables>
          <LiveVariable>
            <Expression>rc.rc</Expression>
            <Enabled>true</Enabled>
            <Breakpoint>
              <ComparisonMode>Equals</ComparisonMode>
              <Enabled>false</Enabled>
            </Breakpoint>
            <Plot>false</Plot>
            <IsCollapsed>false</IsCollapsed>
            <IsFavorite>false</IsFavorite>
          </LiveVariable>
          <LiveVariable>
            <Expression>rc.rc.s</Expression>
            <Type>com.sysprogs.fixed</Type>
            <Enabled>true</Enabled>
            <Breakpoint>
              <ComparisonMode>Equals</ComparisonMode>
