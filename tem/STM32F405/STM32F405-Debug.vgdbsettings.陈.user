        <Type>com.sysprogs.types.builtin.SInt32</Type>
        <Enabled>true</Enabled>
        <Breakpoint>
          <ComparisonMode>Equals</ComparisonMode>
          <Enabled>false</Enabled>
        </Breakpoint>
        <Plot>false</Plot>
        <IsCollapsed>false</IsCollapsed>
        <IsFavorite>false</IsFavorite>
      </LiveVariable>
      <LiveVariable>
        <Expression>Step</Expression>
        <Type>com.sysprogs.types.builtin.SInt32</Type>
        <Enabled>true</Enabled>
        <Breakpoint>
          <ComparisonMode>Equals</ComparisonMode>
