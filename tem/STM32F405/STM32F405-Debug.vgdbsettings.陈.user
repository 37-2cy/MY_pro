<?xml version="1.0"?>
<VisualGDBUserPreferences xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <UserDefinedVariableValues />
  <DebugPreferences xsi:type="com.visualgdb.debug.embedded.preferences">
    <CatchpointConfiguration>
      <Exec>false</Exec>
      <Fork>false</Fork>
      <Vfork>false</Vfork>
      <Syscalls />
      <CXXCatchpoints />
    </CatchpointConfiguration>
    <MaskInterruptsWhileStepping>false</MaskInterruptsWhileStepping>
    <MemoryWindowPreferences>
      <MemoryWindowPreferences>
        <SymbolicMode>true</SymbolicMode>
        <TakeAddressMode>false</TakeAddressMode>
        <Format>
          <DataWidth>OneByte</DataWidth>
          <DataFormat>Hexadecimal</DataFormat>
          <TextFormat>ANSI</TextFormat>
        </Format>
        <LiveMemorySettings>
          <Enabled>false</Enabled>
          <BreakOnChanges>false</BreakOnChanges>
          <AutoRefresh>false</AutoRefresh>
          <RefreshTimeout>0</RefreshTimeout>
        </LiveMemorySettings>
        <ShowStatusBar>true</ShowStatusBar>
        <DisplaySymbols>false</DisplaySymbols>
      </MemoryWindowPreferences>
    </MemoryWindowPreferences>
    <LiveVariables>
      <LiveVariable>
        <Expression>path_ready</Expression>
        <Type>com.sysprogs.types.builtin.SInt32</Type>
        <Enabled>true</Enabled>
        <Breakpoint>
          <ComparisonMode>Equals</ComparisonMode>
          <Enabled>false</Enabled>
        </Breakpoint>
        <Plot>false</Plot>
        <IsCollapsed>false</IsCollapsed>
        <IsFavorite>false</IsFavorite>
      </LiveVariable>
      <LiveVariable>
        <Expression>step_now</Expression>
        <Type>com.sysprogs.types.builtin.SInt32</Type>
        <Enabled>true</Enabled>
        <Breakpoint>
          <ComparisonMode>Equals</ComparisonMode>
          <Enabled>false</Enabled>
        </Breakpoint>
        <Plot>false</Plot>
        <IsCollapsed>false</IsCollapsed>
        <IsFavorite>false</IsFavorite>
