            <Type>com.sysprogs.fixed</Type>
            <Enabled>true</Enabled>
            <Breakpoint>
              <ComparisonMode>Equals</ComparisonMode>
              <Enabled>false</Enabled>
            </Breakpoint>
            <Plot>false</Plot>
            <IsCollapsed>false</IsCollapsed>
            <IsFavorite>false</IsFavorite>
          </LiveVariable>
          <LiveVariable>
            <Expression>stsRx[5]</Expression>
            <Type>com.sysprogs.types.builtin.HexInt8</Type>
            <Enabled>true</Enabled>
            <Breakpoint>
              <ComparisonMode>Equals</ComparisonMode>
              <Enabled>false</Enabled>
            </Breakpoint>
            <Plot>false</Plot>
            <IsCollapsed>false</IsCollapsed>
            <IsFavorite>false</IsFavorite>
